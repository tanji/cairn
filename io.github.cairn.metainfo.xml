<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.cairn</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>Cairn</name>
  <summary>A simple GNOME task manager</summary>

  <description>
    <p>
      Cairn is a straightforward task manager for the GNOME desktop.
      Create and track tasks with optional deadlines and reminders.
      Completed tasks are archived in a history view and can be exported to CSV.
    </p>
    <ul>
      <li>Create and manage tasks with deadlines</li>
      <li>Per-task or global reminder schedules with repeat intervals</li>
      <li>Project grouping with a searchable project picker</li>
      <li>History view with CSV export</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.cairn.desktop</launchable>

  <url type="homepage">https://github.com/tanji/cairn</url>
  <url type="bugtracker">https://github.com/tanji/cairn/issues</url>

